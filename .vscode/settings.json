{
    "python.defaultInterpreterPath": "${workspaceFolder}/.conda/bin/python",
    "python.analysis.extraPaths": [
        "${workspaceFolder}",
        "${workspaceFolder}/.conda/lib/python3.12/site-packages"
    ],
    "python.terminal.activateEnvironment": false,
    "python.terminal.activateEnvInCurrentTerminal": false,
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "python-envs.defaultPackageManager": "ms-python.python:conda",
    "terminal.integrated.enablePersistentSessions": false,
    "terminal.integrated.defaultProfile.linux": "bash (project .conda)",
    "terminal.integrated.profiles.linux": {
        "bash (project .conda)": {
            "path": "/bin/bash",
            "args": [
                "--init-file",
                "${workspaceFolder}/.vscode/bashrc.project",
                "-i"
            ],
            "icon": "terminal-bash"
        }
    }
}